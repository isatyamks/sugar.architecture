# ─────────────────────────────────────────────────────────────
# AI Reflection Service — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# All variables are prefixed with REFLECT_ to avoid collisions.
# ─────────────────────────────────────────────────────────────

# --- Server ---
REFLECT_APP_NAME=ai-reflection-service
REFLECT_DEBUG=true
REFLECT_HOST=0.0.0.0
REFLECT_PORT=8000

# --- LLM Provider ---
# Options: local | ollama | openai | huggingface
REFLECT_LLM_PROVIDER=local
REFLECT_LLM_MODEL_NAME=reflection-v1
REFLECT_LLM_API_KEY=
REFLECT_LLM_API_BASE_URL=
REFLECT_LLM_TIMEOUT_SECONDS=30
REFLECT_LLM_MAX_TOKENS=256

# --- Fallback ---
REFLECT_FALLBACK_ENABLED=true
REFLECT_FALLBACK_PROVIDER=rule_based

# --- Cache ---
REFLECT_CACHE_ENABLED=false
REFLECT_CACHE_TTL_SECONDS=3600

# --- Logging ---
REFLECT_LOG_LEVEL=INFO
REFLECT_LOG_RESPONSES=true

# --- Storage ---
REFLECT_RESPONSE_LOG_DB=sqlite:///reflection_logs.db

# --- Routing ---
REFLECT_DEFAULT_FRAMEWORK=what_so_what
REFLECT_MIN_AGE_FOR_GIBBS=12
